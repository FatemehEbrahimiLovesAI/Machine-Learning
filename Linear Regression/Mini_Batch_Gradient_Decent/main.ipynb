<!DOCTYPE html>
<html lang="fa" dir="ltr">
<head>
<meta charset="UTF-8">
<title>main.py at main · user/repo · GitHub</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/python.min.js"></script>
<style>
  :root{
    --bg-canvas:#ffffff;
    --bg-subtle:#f6f8fa;
    --border-default:#d1d9e0;
    --border-muted:#d8dee4;
    --fg-default:#1f2328;
    --fg-muted:#59636e;
    --accent:#0969da;
    --accent-emphasis:#0969da;
    --btn-bg:#f6f8fa;
    --btn-border:#d1d9e0;
    --hash-bg:#eaeef2;
    --green-fg:#1a7f37;
    --line-num:#8b949e;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--bg-canvas);
    color:var(--fg-default);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif;
    font-size:14px;
    -webkit-font-smoothing:antialiased;
  }
  a{color:var(--accent);text-decoration:none;}
  a:hover{text-decoration:underline;}

  .topbar{
    border-bottom:1px solid var(--border-default);
    padding:16px 32px;
    display:flex;
    align-items:center;
    gap:8px;
    flex-wrap:wrap;
  }
  .topbar svg.octicon-repo{fill:var(--fg-muted);}
  .breadcrumb{
    font-size:20px;
    display:flex;
    align-items:center;
    gap:4px;
    flex-wrap:wrap;
  }
  .breadcrumb .sep{color:var(--fg-muted);padding:0 2px;}
  .breadcrumb .current{font-weight:600;}

  .container{max-width:1280px;margin:0 auto;padding:24px 32px 64px;}

  .tabs{
    display:flex;
    gap:2px;
    border-bottom:1px solid var(--border-default);
    margin-bottom:16px;
  }
  .tab{
    padding:8px 16px 12px;
    font-size:14px;
    color:var(--fg-muted);
    border-bottom:2px solid transparent;
    cursor:default;
    display:flex;align-items:center;gap:6px;
  }
  .tab.active{
    color:var(--fg-default);
    font-weight:600;
    border-bottom-color:#fd8c73;
  }

  .file-toolbar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    background:var(--bg-subtle);
    border:1px solid var(--border-default);
    border-bottom:none;
    border-radius:6px 6px 0 0;
    padding:8px 16px;
    flex-wrap:wrap;
    gap:12px;
  }
  .file-toolbar .left{display:flex;align-items:center;gap:14px;color:var(--fg-muted);font-size:12px;flex-wrap:wrap;}
  .file-toolbar .left b{color:var(--fg-default);font-weight:600;}
  .file-toolbar .right{display:flex;align-items:center;gap:8px;}
  .btn{
    background:var(--btn-bg);
    border:1px solid var(--btn-border);
    border-radius:6px;
    padding:3px 10px;
    font-size:12px;
    color:var(--fg-default);
    cursor:default;
    display:flex;align-items:center;gap:6px;
  }

  .blame-wrap{
    border:1px solid var(--border-default);
    border-radius:0 0 6px 6px;
    overflow-x:auto;
  }
  .blame-grid{
    display:grid;
    grid-template-columns: 300px 56px 1fr;
    min-width:760px;
  }
  .blame-info{
    grid-column:1;
    background:var(--bg-subtle);
    border-right:1px solid var(--border-default);
    padding:12px 16px;
    display:flex;
    gap:8px;
    align-items:flex-start;
    position:sticky;
    left:0;
  }
  .avatar{
    width:24px;height:24px;border-radius:50%;
    background:linear-gradient(135deg,#6e40c9,#1f6feb);
    color:#fff;
    display:flex;align-items:center;justify-content:center;
    font-size:11px;font-weight:600;
    flex-shrink:0;
    margin-top:1px;
  }
  .blame-meta{min-width:0;}
  .blame-meta .msg{
    font-weight:600;
    font-size:12px;
    color:var(--fg-default);
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
    display:block;
    margin-bottom:2px;
  }
  .blame-meta .msg a{color:var(--fg-default);}
  .blame-meta .msg a:hover{color:var(--accent);}
  .blame-meta .sub{
    font-size:12px;
    color:var(--fg-muted);
  }
  .blame-meta .sub b{color:var(--fg-default);font-weight:600;}
  .blame-meta .hash{
    display:inline-block;
    margin-top:4px;
    font-family:ui-monospace,SFMono-Regular,"SF Mono",Consolas,monospace;
    font-size:11px;
    background:var(--hash-bg);
    color:var(--fg-muted);
    padding:0 4px;
    border-radius:4px;
  }

  .line-num{
    grid-column:2;
    text-align:right;
    padding:0 8px;
    color:var(--line-num);
    font-family:ui-monospace,SFMono-Regular,"SF Mono",Consolas,monospace;
    font-size:12px;
    line-height:20px;
    user-select:none;
    border-right:1px solid var(--border-muted);
    background:var(--bg-canvas);
}
  .line-code{
    grid-column:3;
    padding:0 16px;
    font-family:ui-monospace,SFMono-Regular,"SF Mono",Consolas,monospace;
    font-size:12px;
    line-height:20px;
    white-space:pre;
    background:var(--bg-canvas);
  }
  .line-num:hover, .line-row-hover .line-num{color:var(--accent);}
  .line-code .hljs{background:transparent;padding:0;}

  .footer-note{
    margin-top:14px;
    font-size:12px;
    color:var(--fg-muted);
  }
</style>
</head>
<body>

  <div class="topbar">
    <svg class="octicon-repo" height="16" width="16" viewBox="0 0 16 16"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z"></path></svg>
    <div class="breadcrumb">
      <a href="#">user</a>
      <span class="sep">/</span>
      <a href="#">repo</a>
    </div>
  </div>

  <div class="container">

    <div class="tabs">
      <div class="tab" style="cursor:default;">&lt;&gt; Code</div>
      <div class="tab active">
        <svg height="16" width="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13ZM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8Zm9.5-5a.5.5 0 0 1 .5.5v3.5h2.25a.75.75 0 0 1 0 1.5h-3a.75.75 0 0 1-.75-.75V4a.5.5 0 0 1 .5-.5Z"></path></svg>
        Blame
      </div>
    </div>

    <div class="file-toolbar">
      <div class="left">
        <span>133 lines</span>
        <span>·</span>
        <span><b>4.1</b> KB</span>
      </div>
      <div class="right">
        <span class="btn">Raw</span>
        <span class="btn">Copy</span>
        <span class="btn">Blame ▾</span>
      </div>
    </div>

    <div class="blame-wrap">
      <div class="blame-grid" id="blame-grid"></div>
    </div>

    <p class="footer-note">
      نکته: گیت‌هاب blame را از روی تاریخچه‌ی commit واقعی می‌سازد؛ چون این فایل از قبل گیت ندارد، کل فایل به‌صورت یک commit فرضی («Add main.py») نشان داده شده و کدها بدون هیچ تغییری از main.ipynb استخراج شده‌اند. اگر نام نویسنده، پیام commit یا هش واقعی را بدهید، دقیقاً همان را جایگزین می‌کنم.
    </p>

  </div>

<script>
const LINES = ["import pandas as pd", "import numpy as np", "from sklearn.datasets import fetch_california_housing", "from sklearn.model_selection import train_test_split", "", "dataset = fetch_california_housing()", "", "df = pd.DataFrame(data=dataset['data'],columns=dataset['feature_names'])", "df.head()", "", "features = ['MedInc','HouseAge','AveRooms','AveBedrms','Population','AveOccup','Latitude','Longitude']", "", "for feature in features:", "    df[feature] = df[feature].replace(0,None)", "    mean_value = np.mean(df[feature])", "    df[feature] = df[feature].fillna(mean_value)", "", "df.head()", "", "", "for feature in features:", "    min_value = np.min(df[feature])", "    max_value = np.max(df[feature])", "    df[feature] = (df[feature] - min_value ) / (max_value - min_value)", "", "df.head()", "", "X = df.iloc[:,:]", "y = np.array(dataset['target'])", "", "X_train , X_test , y_train , y_test = train_test_split(X,y,train_size=0.8,random_state=12)", "", "def gradient(X,y,y_hat):", "    grads = []", "    for xi in X.T:", "        grads.append(2 * np.mean(xi * (y_hat - y)))", "    return np.array(grads) ", "", "def update(w,eta,grads):", "    return w - (eta * grads)", "", "def multi_variable_regression(X,w):", "    return X @ w ", "", "def make_batches(X,y,batch_size):", "    X_batches = []", "    y_batches = []", "    for i in range(0,len(X),batch_size):", "        X_batches.append(X[i:i+batch_size])", "        y_batches.append(y[i:i+batch_size])", "    return np.array(X_batches),np.array(y_batches)", "", "def loss_batch(y_batch,y_hat):", "    return np.mean((y_batch - y_hat) **2)", "", "m,n = X.shape", "m,n", "", "batch_size = 8", "X_batches, y_batches = make_batches(X_train,y_train,batch_size)", "X_batches.shape , y_batches.shape , X_train.shape, y_train.shape", "", "16512 / 8", "", "epoches = 1000", "eta = 0.1", "w = np.random.randn(n)", "", "for epoch in range(epoches):", "    losses = []", "", "    for (X_batch,y_batch) in zip(X_batches,y_batches):", "        y_hat = multi_variable_regression(X_batch,w)", "        loss = loss_batch(y_batch,y_hat)", "        losses.append(loss)", "        grads = gradient(X_batch,y_batch,y_hat)", "        w = update(w,eta,grads)", "    print(f'epoch : {epoch+1} mse: {np.mean(losses)}')", "", "def mse_score(y_batch,y_hat):", "    return np.mean((y_batch - y_hat) **2)", "", "def mae_score(y_batch,y_hat):", "    return np.mean(abs(y_batch - y_hat))", "", "def r2_score(y_batch, y_hat):", "    return 1 - sum((y_batch - y_hat) ** 2) / sum((y_batch - y_batch.mean()) ** 2)", "", "", "", "batch_size = 32", "X_batches, y_batches = make_batches(X_train,y_train,batch_size)", "X_batches.shape , y_batches.shape , X_train.shape, y_train.shape", "# w = np.random.randn(n)", "w = [-1.8145861 ,  1.00559584, -0.34816822, -1.57737987, -1.42116979,", "       -0.32263432, -1.10406993, -0.87049433]", "", "epoches = 1000", "eta = 0.1", "", "main_mse_loss = []", "main_mae_loss = []", "main_r2_loss = []", "", "for epoch in range(epoches):", "    epoch_mse_loss = []", "    epoch_mae_loss = []", "    epoch_r2_loss = []", "", "    for (X_batch,y_batch) in zip(X_batches,y_batches):", "", "        y_hat = multi_variable_regression(X_batch,w)", "", "        mse = mse_score(y_batch,y_hat)", "        mae = mae_score(y_batch,y_hat)", "        r2 = r2_score(y_batch,y_hat)", "", "        epoch_mse_loss.append(mse)", "        epoch_mae_loss.append(mae)", "        epoch_r2_loss.append(r2)", "", "        grads = gradient(X_batch,y_batch,y_hat)", "        w = update(w,eta,grads)", "    ", "    main_mse_loss.append(np.mean(epoch_mse_loss))", "    main_mae_loss.append(np.mean(epoch_mae_loss))", "    main_r2_loss.append(np.mean(epoch_r2_loss))", "", "print(f\"mse : {np.mean(main_mse_loss)}\\nmae : {np.mean(main_mae_loss)}\\nr2 : {np.mean(main_r2_loss)}\")", "", "y_hat = multi_variable_regression(X_test,w)", "print(mse_score(y_test,y_hat))", "print(r2_score(y_test,y_hat))"];

function escapeHtml(s){
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

const grid = document.getElementById('blame-grid');

// single synthetic blame chunk spanning the whole file
const info = document.createElement('div');
info.className = 'blame-info';
info.style.gridRow = `1 / span ${LINES.length}`;
info.innerHTML = `
  <div class="avatar">U</div>
  <div class="blame-meta">
    <span class="msg"><a href="#">Add main.py</a></span>
    <span class="sub"><b>user</b> committed now</span><br>
    <span class="hash">a1b2c3d</span>
  </div>
`;
grid.appendChild(info);

LINES.forEach((line, idx) => {
  const num = document.createElement('div');
  num.className = 'line-num';
  num.textContent = idx + 1;
  grid.appendChild(num);

  const code = document.createElement('div');
  code.className = 'line-code';
  const codeEl = document.createElement('code');
  codeEl.className = 'language-python';
  codeEl.textContent = line.length ? line : ' ';
  code.appendChild(codeEl);
  grid.appendChild(code);
});

document.querySelectorAll('.line-code code').forEach(el => {
  try { hljs.highlightElement(el); } catch(e) {}
});
</script>
</body>
</html>
